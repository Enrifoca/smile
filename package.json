{
  "name": "smile",
  "version": "0.2.0",
  "description": "White-label desktop framework for building vertical AI agents",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "author": "Enrico Focaccia",
  "repository": {
    "type": "git",
    "url": "https://github.com/enrifoca/smile.git"
  },
  "scripts": {
    "dev": "node scripts/brand-electron.mjs && node scripts/dev-electron.mjs",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "release": "tsc && vite build && electron-builder --publish always",
    "release:win": "tsc && vite build && electron-builder --win --publish always",
    "release:mac": "tsc && vite build && electron-builder --mac --publish always",
    "preview": "vite preview",
    "electron:dev": "node scripts/brand-electron.mjs && node scripts/dev-electron.mjs",
    "typecheck": "tsc --noEmit",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "validate:sandbox": "electron scripts/validate-sandbox.cjs",
    "validate:contract": "node packages/connector-sdk/bin/smile-connector.cjs check-contract",
    "validate:connector": "node packages/connector-sdk/bin/smile-connector.cjs validate",
    "test:connector": "node packages/connector-sdk/bin/smile-connector.cjs test",
    "icons": "node scripts/generate-icons.mjs && node scripts/brand-electron.mjs",
    "brand-electron": "node scripts/brand-electron.mjs",
    "postinstall": "electron-builder install-app-deps && node scripts/brand-electron.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "form-data": "^4.0.5",
    "jsdom": "^25.0.0",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "mcp-remote": "^0.1.37",
    "mime-types": "^3.0.2",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ripgrep": "^0.3.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@smile/connector-sdk": "file:packages/connector-sdk",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "png2icons": "^2.0.1",
    "postcss": "^8.4.38",
    "rcedit": "^5.0.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.4",
    "to-ico": "^1.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "undici": "^6.21.0"
  },
  "build": {
    "appId": "com.smile.framework",
    "productName": "smile:D",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "bundled/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon-windows.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "enrifoca",
      "repo": "smile",
      "releaseType": "release"
    }
  }
}
